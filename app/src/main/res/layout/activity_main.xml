<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_gradient"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <Space android:layout_width="match_parent" android:layout_height="36dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:text="AIS NO PRO"
            android:textColor="@color/accent_cyan"
            android:textSize="32sp"
            android:textStyle="bold"
            android:letterSpacing="0.05" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:layout_marginTop="4dp"
            android:text="Fast &amp; Secure SSH Tunnel"
            android:textColor="@color/text_secondary"
            android:textSize="13sp" />

        <Space android:layout_width="match_parent" android:layout_height="18dp" />

        <LinearLayout
            android:id="@+id/expiryChip"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:background="@drawable/bg_chip"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:paddingTop="8dp"
            android:paddingBottom="8dp">

            <TextView
                android:id="@+id/dotExpiry"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="●"
                android:textColor="@color/success"
                android:textSize="10sp" />

            <TextView
                android:id="@+id/tvExpiry"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:text="Account expiry: --"
                android:textColor="@color/success"
                android:textSize="13sp"
                android:textStyle="bold" />
        </LinearLayout>

        <Space android:layout_width="match_parent" android:layout_height="28dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/bg_card"
            android:padding="22dp"
            android:elevation="6dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Import SSH Link (Netmod)"
                android:textColor="@color/text_secondary"
                android:textSize="12sp" />

            <EditText
                android:id="@+id/etImportLink"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:background="@drawable/bg_field"
                android:paddingStart="14dp"
                android:paddingEnd="14dp"
                android:layout_marginTop="6dp"
                android:textColor="@color/text_primary"
                android:textColorHint="#5C6291"
                android:hint="Paste ssh:// link here"
                android:inputType="textUri"
                android:maxLines="1"
                android:singleLine="true" />

            <Space android:layout_width="match_parent" android:layout_height="10dp" />

            <Button
                android:id="@+id/btnParseLink"
                android:layout_width="match_parent"
                android:layout_height="46dp"
                android:background="@drawable/bg_btn_outline"
                android:text="PARSE LINK"
                android:textColor="@color/accent_cyan"
                android:textSize="13sp"
                android:textStyle="bold" />

            <Space android:layout_width="match_parent" android:layout_height="14dp" />

            <TextView
                android:id="@+id/tvParsedServer"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Server: --"
                android:textColor="@color/text_secondary"
                android:textSize="12sp" />

            <Space android:layout_width="match_parent" android:layout_height="16dp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="SSH Username"
                android:textColor="@color/text_secondary"
                android:textSize="12sp" />
            <EditText
                android:id="@+id/etUser"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:background="@drawable/bg_field"
                android:paddingStart="14dp"
                android:paddingEnd="14dp"
                android:layout_marginTop="6dp"
                android:textColor="@color/text_primary"
                android:textColorHint="#5C6291"
                android:hint="Enter your username" />

            <Space android:layout_width="match_parent" android:layout_height="16dp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="SSH Password"
                android:textColor="@color/text_secondary"
                android:textSize="12sp" />
            <EditText
                android:id="@+id/etPass"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:background="@drawable/bg_field"
                android:paddingStart="14dp"
                android:paddingEnd="14dp"
                android:layout_marginTop="6dp"
                android:textColor="@color/text_primary"
                android:textColorHint="#5C6291"
                android:hint="Enter your password"
                android:inputType="textPassword" />

        </LinearLayout>

        <Space android:layout_width="match_parent" android:layout_height="22dp" />

        <TextView
            android:id="@+id/tvStatus"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Not connected"
            android:textColor="@color/text_secondary"
            android:textSize="13sp"
            android:gravity="center"
            android:layout_marginBottom="14dp" />

        <Button
            android:id="@+id/btnConnect"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:background="@drawable/bg_btn_connect"
            android:text="CONNECT"
            android:textColor="#0B0E1E"
            android:textStyle="bold"
            android:textSize="15sp"
            android:letterSpacing="0.05"
            android:elevation="4dp" />

        <Space android:layout_width="match_parent" android:layout_height="12dp" />

        <Button
            android:id="@+id/btnDisconnect"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:background="@drawable/bg_btn_outline"
            android:text="DISCONNECT"
            android:textColor="@color/danger"
            android:textStyle="bold"
            android:textSize="14sp" />

        <Space android:layout_width="match_parent" android:layout_height="24dp" />

    </LinearLayout>
</ScrollView>
